---
import CaseSection from '../components/home/CaseSection.astro';
import EducationSection from '../components/home/EducationSection.astro';
import EmbodiedSection from '../components/home/EmbodiedSection.astro';
import FactorySection from '../components/home/FactorySection.astro';
import HomeHero from '../components/home/HomeHero.astro';
import ProjectCta from '../components/home/ProjectCta.astro';
import PartnerMarquee from '../components/home/PartnerMarquee.astro';
import SolutionSplit from '../components/home/SolutionSplit.astro';
import TechnologySection from '../components/home/TechnologySection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveImage } from '../lib/images';
---

<BaseLayout
  title="天津光泰科技集团 | AI应用工厂与数智化解决方案"
  description="以光泰AI应用工厂为平台底座，融合大模型、知识库、智能体、AI编程、具身智能与系统集成能力。"
  ogImage={resolveImage('/assets/hero-humanoid-ai-campus.png').src}
>
  <main>
    <HomeHero /><FactorySection /><EmbodiedSection /><PartnerMarquee
    /><SolutionSplit /><EducationSection /><TechnologySection /><CaseSection
    /><ProjectCta />
  </main>
</BaseLayout>
