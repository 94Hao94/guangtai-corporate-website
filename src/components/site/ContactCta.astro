---
interface Props {
  contact?: boolean;
}
const { contact = false } = Astro.props;
---

<section class="inner-cta">
  <div>
    <p>START A PROJECT</p><h2>
      {contact ? '从一个真实问题开始' : '让AI、系统与真实场景在同一张蓝图上'}
    </h2>
  </div><a data-route-cta href={contact ? '/solutions/common' : '/contact'}
    >{contact ? '浏览解决方案' : '项目咨询'}<span>↗</span></a
  >
</section>
