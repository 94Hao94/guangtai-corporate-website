---
const cases = [
  ['校园AI智能体', '知识库、教师助手、学习服务与管理流程智能体。'],
  [
    '具身智能实训与巡检',
    '人形、四足与轮式设备的任务编排、数据回传和运行管理。',
  ],
  [
    '智能空间与系统集成',
    '会议、报告、展示、安防、机房与业务系统的一体化建设。',
  ],
];
---

<section class="cases section-pad">
  <div class="section-heading" data-reveal>
    <p class="eyebrow">PROJECT PRACTICE</p><h2>以客户真实建设需求为起点</h2><p>
      官网不虚构数量与客户名称。以下作为可替换的项目实践类型，待真实案例材料确认后更新。
    </p>
  </div><div class="case-row">
    {
      cases.map(([title, text], index) => (
        <article data-reveal>
          <>
            <span>PROJECT TYPE / 0{index + 1}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </>
        </article>
      ))
    }
  </div>
</section>
