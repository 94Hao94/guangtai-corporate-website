---
import { Image } from 'astro:assets';
import { resolveImage } from '../../lib/images';
import DataNetwork from './DataNetwork.astro';
const hero = resolveImage('/assets/hero-humanoid-ai-campus.png');
---

<section id="home" class="home-hero">
  <Image
    class="hero-image"
    src={hero}
    alt=""
    widths={[768, 1280, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <div class="hero-wash" aria-hidden="true"></div><DataNetwork />
  <div
    class="hero-spline"
    data-spline-hero
    data-spline-scene="https://prod.spline.design/JCd7StIa9lqPaRfw/scene.splinecode?v=robot-v2"
    aria-label="可交互的机器人 3D 模型"
  >
  </div>
  <div class="hero-copy">
    <h1>光启未来 智领时代</h1>
    <div class="hero-context">
      <p class="hero-description">
        以AI应用工厂为平台底座，融合软件开发、系统集成、空间智能与具身设备。
      </p>
      <p class="hero-company">天津光泰科技集团有限公司</p>
    </div>
    <div class="hero-actions">
      <a class="button button-primary" data-route-cta href="/about"
        >了解更多 <span>→</span></a
      >
    </div>
  </div>
</section>
<script>
  import { canAutoMountSplineHero } from '../../lib/spline-capability';

  declare global {
    interface Window {
      splineHeroLifecycleReady?: boolean;
    }
  }

  /**
   * Mounts the Spline scene only when the browser reports enough desktop, hardware, and network capacity.
   * @returns Nothing. Unsupported, low-capability, or failed viewers retain the static Hero fallback.
   * @throws Never intentionally throws; a failed dynamic import leaves the fallback in place.
   */
  const initializeSplineHero = async (): Promise<void> => {
    const host = document.querySelector<HTMLElement>('[data-spline-hero]');
    const scene = host?.dataset.splineScene;
    if (!host || !scene || host.childElementCount > 0) return;

    const navigatorWithSignals = navigator as Navigator & {
      deviceMemory?: number;
      connection?: { saveData?: boolean; effectiveType?: string };
    };
    const canRender3d = canAutoMountSplineHero({
      viewportWidth: window.innerWidth,
      reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)')
        .matches,
      hardwareConcurrency: navigator.hardwareConcurrency,
      deviceMemory: navigatorWithSignals.deviceMemory,
      saveData: navigatorWithSignals.connection?.saveData,
      effectiveType: navigatorWithSignals.connection?.effectiveType,
    });
    host.dataset.splineMode = canRender3d ? 'interactive' : 'static';
    if (!canRender3d) return;

    try {
      await import('@splinetool/viewer');
      const viewer = document.createElement('spline-viewer');
      viewer.setAttribute('url', scene);
      viewer.setAttribute('aria-label', '可交互的机器人 3D 模型');
      viewer.addEventListener(
        'load',
        () => {
          host.closest('.home-hero')?.classList.add('has-spline');
          host.closest('.home-hero')?.classList.add('is-spline-mounted');
        },
        { once: true },
      );
      viewer.addEventListener(
        'error',
        () => {
          viewer.remove();
          host.dataset.splineMode = 'static';
        },
        { once: true },
      );
      host.replaceChildren(viewer);
    } catch {
      host.dataset.splineMode = 'static';
    }
  };

  if (!window.splineHeroLifecycleReady) {
    window.splineHeroLifecycleReady = true;
    document.addEventListener('astro:page-load', initializeSplineHero);
    void initializeSplineHero();
  }
</script>
