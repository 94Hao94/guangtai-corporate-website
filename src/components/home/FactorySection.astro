---
import { Image } from 'astro:assets';
import { factoryLayers } from '../../data/home';
import { resolveImage } from '../../lib/images';
import HomeChapter from './HomeChapter.astro';
---

<section class="factory section-pad">
  <HomeChapter number="01" title="AI 应用工厂" english="GUANGTAI AI FACTORY" />
  <div class="section-heading" data-reveal>
    <p class="eyebrow">GUANGTAI AI FACTORY</p><h2>
      把模型、知识、工具和流程<br />编排成可运行的行业智能体
    </h2>
  </div><div class="factory-layout">
    <div class="factory-visual" data-reveal>
      <Image
        src={resolveImage('/assets/ai-factory.png')}
        alt="光泰AI应用工厂能力架构"
        widths={[720, 1100]}
        sizes="(max-width: 900px) 100vw, 55vw"
      />
    </div><div class="factory-layers">
      {
        factoryLayers.map(([title, text], index) => (
          <article data-reveal>
            <>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </>
              </div>
            </>
          </article>
        ))
      }<a class="text-link" href="/guangtai-ai-factory"
        >查看完整平台架构 <span>→</span></a
      >
    </div>
  </div>
</section>
