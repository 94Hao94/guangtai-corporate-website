---
import { partners } from '../../data/partners';
import HomeChapter from './HomeChapter.astro';
---

<section
  class="partner-marquee section-pad"
  data-partner-marquee
  aria-label="合作伙伴"
>
  <HomeChapter
    number="02.1"
    title="具身生态伙伴"
    english="EMBODIED ECOSYSTEM"
  />
  <div class="section-heading" data-reveal>
    <p class="eyebrow">PARTNERS</p><h2>与具身智能伙伴，共同进入真实场景</h2>
  </div>
  <div class="partner-viewport">
    <div class="partner-track" data-partner-track>
      {
        partners.map((partner) => (
          <a
            href={partner.href}
            target="_blank"
            rel="noreferrer"
            data-partner-logo-surface={partner.logoSurface}
          >
            <img
              class="partner-logo"
              src={partner.logo}
              alt={partner.logoAlt}
              loading="eager"
              decoding="async"
            />
          </a>
        ))
      }
      <div aria-hidden="true">
        {
          partners.map((partner) => (
            <span data-partner-logo-surface={partner.logoSurface}>
              <img
                class="partner-logo"
                src={partner.logo}
                alt=""
                loading="eager"
                decoding="async"
              />
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
