---
import Container from './Container.astro';

interface Props {
  company: string;
}

const { company } = Astro.props;
---

<footer>
  <Container>
    <p>© {new Date().getUTCFullYear()} {company}。保留所有权利。</p>
  </Container>
</footer>

<style>
  footer {
    padding-block: 2rem;
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
  }

  p {
    margin: 0;
  }
</style>
