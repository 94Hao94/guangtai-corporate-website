---
import { Image } from 'astro:assets';
import ChapterNav from '../site/ChapterNav.astro';
import ContactCta from '../site/ContactCta.astro';
import type { SitePage } from '../../lib/page-schema';
import { resolveImage } from '../../lib/images';
import CapabilityNavigator from './CapabilityNavigator.astro';
import ContactForm from './ContactForm.astro';
import DeliverySection from './DeliverySection.astro';
import FactoryExperienceCta from './FactoryExperienceCta.astro';
import InnerHero from './InnerHero.astro';
import RelatedPages from './RelatedPages.astro';
import ScenarioSection from './ScenarioSection.astro';
interface Props {
  page: SitePage;
  ancestors: SitePage[];
  children: SitePage[];
  related: SitePage[];
}
const { page, ancestors, children, related } = Astro.props;
const isAbout = page.path === '/about';
const isContact = page.path === '/contact';
const isFactory = page.path === '/guangtai-ai-factory';
---

<main
  class:list={[
    'inner-page',
    `template-${page.template}`,
    `family-${page.visualFamily}`,
  ]}
  data-page-motion
>
  <InnerHero page={page} ancestors={ancestors} /><ChapterNav
    showMatrix={children.length > 0}
    showScenarios={!isAbout && !isFactory && !isContact}
    showDelivery={isAbout || (!isFactory && !isContact)}
    showCapabilities={isContact}
  />
  {
    isContact ? (
      <section id="overview" class="inner-intro inner-section" data-reveal>
        <>
          <div class="section-kicker">
            <>
              <span>01</span>
              <div>
                <>
                  <b>定位与价值</b>
                  <small>POSITIONING & VALUE</small>
                  <p>
                    从业务目标出发，形成可建设、可交付、可持续运营的能力组合。
                  </p>
                </>
              </div>
            </>
          </div>
          <div class="inner-intro-copy">
            <>
              <h2>{page.intro}</h2>
              <p>{page.positioning}</p>
            </>
          </div>
        </>
      </section>
    ) : (
      <CapabilityNavigator page={page} />
    )
  }
  {
    children.length > 0 && (
      <section id="matrix" class="inner-matrix inner-section" data-reveal>
        <>
          <div class="inner-heading">
            <>
              <p>SCENARIO MATRIX</p>
              <h2>从一个统一入口，进入具体能力与场景</h2>
            </>
          </div>
          <div class="matrix-grid">
            {children.map((child, index) => (
              <a href={child.path} class="matrix-card">
                <Image
                  src={resolveImage(child.hero)}
                  alt={`${child.title}场景`}
                  widths={[480, 720]}
                  sizes="(max-width: 760px) 100vw, 33vw"
                />
                <span>
                  {String(index + 1).padStart(2, '0')} / {child.english}
                </span>
                <h3>{child.title}</h3>
                <p>{child.intro}</p>
                <b>查看详情 →</b>
              </a>
            ))}
          </div>
        </>
      </section>
    )
  }
  {isContact && <ContactForm />}
  {isFactory && <FactoryExperienceCta />}
  {!isAbout && !isFactory && !isContact && <ScenarioSection page={page} />}
  {isAbout && <DeliverySection page={page} compact />}
  {!isAbout && !isFactory && !isContact && <DeliverySection page={page} />}
  {!isFactory && !isContact && <RelatedPages pages={related} />}
  {!isFactory && !isContact && <ContactCta />}
</main>
