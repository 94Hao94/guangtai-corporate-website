{
  "name": "astro-foundation",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest run --exclude tests/rendered-site.test.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run check && npm test && npm run build && npm run test:rendered && npm run test:e2e:run",
    "import:mvp-content": "tsx scripts/import-mvp-content.ts",
    "import:mvp-assets": "node scripts/import-mvp-assets.mjs",
    "test:rendered": "vitest run tests/rendered-site.test.ts",
    "test:e2e": "npm run build && npm run test:e2e:run",
    "test:e2e:run": "playwright test",
    "verify:container": "node scripts/verify-container.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@splinetool/viewer": "^1.12.98",
    "@storyblok/astro": "^10.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "gsap": "^3.15.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
